# ──────────────────────────────────────────────────────────────────────────────
# Application
# ──────────────────────────────────────────────────────────────────────────────
APP_NAME=MarrakechNutrition
APP_ENV=production          # local | production
APP_KEY=                    # Generate with: php artisan key:generate
APP_DEBUG=false             # MUST be false in production
APP_URL=https://yourdomain.com

APP_LOCALE=fr
APP_FALLBACK_LOCALE=fr
APP_FAKER_LOCALE=fr_FR

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

# ──────────────────────────────────────────────────────────────────────────────
# Logging
# ──────────────────────────────────────────────────────────────────────────────
LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=error             # debug in local, error in production

# ──────────────────────────────────────────────────────────────────────────────
# Database  (MySQL recommended for production)
# ──────────────────────────────────────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=marrakechnutrition
DB_USERNAME=root
DB_PASSWORD=

# ──────────────────────────────────────────────────────────────────────────────
# Session, Cache & Queue
# ──────────────────────────────────────────────────────────────────────────────
SESSION_DRIVER=database     # Use 'database' or 'redis' in production
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public      # Required for product image uploads via storage:link
QUEUE_CONNECTION=database   # Use 'redis' for high-traffic environments

CACHE_STORE=database        # Use 'redis' for high-traffic environments

# ──────────────────────────────────────────────────────────────────────────────
# Redis (optional — use for session/cache/queue in production)
# ──────────────────────────────────────────────────────────────────────────────
REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

# ──────────────────────────────────────────────────────────────────────────────
# Mail
# ──────────────────────────────────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=smtp.example.com
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="contact@marrakechnutrition.ma"
MAIL_FROM_NAME="${APP_NAME}"

# ──────────────────────────────────────────────────────────────────────────────
# Storage (AWS S3 — optional, for cloud image storage)
# ──────────────────────────────────────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=eu-west-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

# ──────────────────────────────────────────────────────────────────────────────
# Vite
# ──────────────────────────────────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
